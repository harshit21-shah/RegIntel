# Copy to .env on your EC2 server before: docker compose -f docker-compose.aws.yml up -d --build

APP_ENV=staging
LOG_LEVEL=INFO

# Replace with your EC2 public IP or domain (no trailing slash)
APP_BASE_URL=http://YOUR_EC2_PUBLIC_IP:3000
CORS_ORIGINS=http://YOUR_EC2_PUBLIC_IP:3000

# REQUIRED — generate a long random string (32+ chars)
JWT_SECRET_KEY=change-me-to-a-long-random-string-before-deploy

# REQUIRED for Query / agents (free tier at https://console.groq.com)
GROQ_API_KEY=

# Optional fallbacks
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Database passwords (change from defaults for anything public-facing)
POSTGRES_PASSWORD=regintel-change-me
NEO4J_PASSWORD=regintel-change-me

# Reranker — heuristic works without extra API keys
RERANKER_PROVIDER=heuristic

# LLM routing
LLM_PRIMARY_PROVIDER=groq
LLM_FALLBACK_PROVIDER=anthropic
LLM_HAIKU_MODEL=llama-3.1-8b-instant
LLM_SONNET_MODEL=llama-3.3-70b-versatile

AUTO_BOOTSTRAP_SEARCH=true
QDRANT_COLLECTION=clauses_v1
