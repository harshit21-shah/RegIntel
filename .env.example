# Application
APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Postgres
DATABASE_URL=postgresql+asyncpg://regintel:regintel@localhost:5433/regintel

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=regintel

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=clauses_v1

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS (production/staging)
AWS_REGION=us-east-1
SQS_QUEUE_URL=
S3_DOCUMENTS_BUCKET=

# Langfuse (optional — self-hosted tracing)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# JWT (required in staging/production — change secret before deploy)
JWT_SECRET_KEY=dev-only-change-me-before-production-deploy-32b
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Rate limits & cost caps
RATE_LIMIT_QUERY_PER_MINUTE=30
RATE_LIMIT_BULK_PER_MINUTE=100
TENANT_DAILY_COST_CAP_USD=50.0
GLOBAL_DAILY_COST_CAP_USD=500.0
INGESTION_STALENESS_HOURS=48

# Bootstrap
AUTO_BOOTSTRAP_SEARCH=true

# Reranker: heuristic | bge | cohere
RERANKER_PROVIDER=heuristic
RERANK_TOP_N=25
COHERE_API_KEY=

# Product alerts (CRITICAL briefs)
SLACK_WEBHOOK_URL=
SES_FROM_EMAIL=
APP_BASE_URL=http://localhost:3000
ALERT_CHANNELS=slack,email

# LLM providers (required for agent pipeline; optional for Phase 0 health checks)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=

# LLM routing defaults (Groq primary, Anthropic fallback)
LLM_PRIMARY_PROVIDER=groq
LLM_FALLBACK_PROVIDER=anthropic
LLM_HAIKU_MODEL=llama-3.1-8b-instant
LLM_SONNET_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_HAIKU_MODEL=claude-3-5-haiku-20241022
LLM_FALLBACK_SONNET_MODEL=claude-3-5-sonnet-20241022
